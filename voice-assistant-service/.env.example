# ═══════════════════════════════════════════════════════════════════════════════
# VOICE ASSISTANT SERVICE – variables de entorno
# Pipeline: STT (Gemini) → LLM + tool calling (Gemini) → TTS (Gemini)
# En GCP: deploya como Cloud Run Service. No requiere estado persistente.
# ═══════════════════════════════════════════════════════════════════════════════

PORT=8090

# ─── Gemini API ────────────────────────────────────────────────────────────────
# En GCP: guarda en Secret Manager y referencia desde Cloud Run como secret env var.
GOOGLE_API_KEY=
# Alias alternativo (se usa si GOOGLE_API_KEY está vacío)
GEMINI_API_KEY=

# Modelo para STT + LLM. gemini-2.5-flash es el recomendado (equilibrio calidad/coste).
GEMINI_DIALOG_MODEL=gemini-2.5-flash
# Alias de compatibilidad (se usa solo si GEMINI_DIALOG_MODEL está vacío)
GEMINI_MODEL=

# Modelo TTS para síntesis de voz española
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# Voz Gemini: Aoede (femenina), Puck (masculina), Charon, Kore, Fenrir, Orbit...
GEMINI_VOICE_NAME=Aoede
# Idioma BCP-47 para TTS
GEMINI_LANGUAGE=es-ES

# Timeout por llamada a Gemini en ms (STT, LLM y TTS tienen este mismo límite)
GEMINI_TIMEOUT_MS=15000
GEMINI_MAX_OUTPUT_TOKENS=512
GEMINI_TEMPERATURE=0.35

# ─── WebSocket ─────────────────────────────────────────────────────────────────
# Orígenes permitidos para conexiones WebSocket.
# En GCP: pon la URL del frontend y la del gateway, separadas por coma.
# Ejemplo: https://tu-frontend.web.app,https://gateway-xxxx.run.app
VOICE_ALLOWED_ORIGINS=*
VOICE_WS_HEARTBEAT_INTERVAL_MS=25000
VOICE_WS_IDLE_TIMEOUT_MS=240000

# ─── Límites de petición ───────────────────────────────────────────────────────
VOICE_RATE_LIMIT_WINDOW_MS=60000
VOICE_RATE_LIMIT_MAX_REQUESTS=40
VOICE_MAX_TEXT_CHARS=450
# ~4 MB de audio en base64
VOICE_MAX_AUDIO_BASE64_CHARS=5500000
VOICE_MAX_STREAM_CHUNKS=32
VOICE_INCLUDE_AUDIO_BY_DEFAULT=true
VOICE_INCLUDE_LATENCY_META=true

# ─── Contexto de gasolineras (gateway) ────────────────────────────────────────
# Activa bootstrap de gasolinera más cercana al inicio de la sesión.
VOICE_ENABLE_GAS_CONTEXT=false
# En GCP: usa la URL interna de Cloud Run del gateway.
# Ejemplo: https://gateway-xxxx-ew.a.run.app
GATEWAY_BASE_URL=http://gateway:8080
VOICE_GATEWAY_TIMEOUT_MS=5000
VOICE_MAX_KM=25
# Secreto compartido entre servicios internos – genera uno largo aleatorio.
INTERNAL_API_SECRET=

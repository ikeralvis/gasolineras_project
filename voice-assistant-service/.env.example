PORT=8090

# OpenAI (single-provider setup)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Intent routing + LLM respuesta
OPENAI_ROUTER_MODEL=gpt-4o-mini
OPENAI_LLM_MODEL=gpt-4o-mini

# STT (Whisper)
OPENAI_STT_MODEL=whisper-1

# TTS
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova
OPENAI_TTS_FORMAT=mp3

# MCP endpoint (si se usa un bridge HTTP o cliente local)
MCP_GATEWAY_MODE=rest
GATEWAY_BASE_URL=http://gateway:8080
INTERNAL_API_SECRET=replace-me

# Cost controls
VOICE_RATE_LIMIT_WINDOW_MS=60000
VOICE_RATE_LIMIT_MAX_REQUESTS=40
VOICE_MAX_TEXT_CHARS=450
VOICE_MAX_AUDIO_BASE64_CHARS=5500000
VOICE_MAX_KM=25
VOICE_ENABLE_TTS_AUDIO=true

# OpenAI request controls
OPENAI_TIMEOUT_MS=12000
OPENAI_ROUTER_MAX_TOKENS=80
OPENAI_LLM_MAX_TOKENS=180

PORT=8090

# WebSocket runtime
VOICE_ALLOWED_ORIGINS=*
VOICE_WS_HEARTBEAT_INTERVAL_MS=25000
VOICE_WS_IDLE_TIMEOUT_MS=240000

# Request limits
VOICE_RATE_LIMIT_WINDOW_MS=60000
VOICE_RATE_LIMIT_MAX_REQUESTS=40
VOICE_MAX_TEXT_CHARS=450
VOICE_MAX_AUDIO_BASE64_CHARS=5500000
VOICE_MAX_STREAM_CHUNKS=32
VOICE_INCLUDE_AUDIO_BY_DEFAULT=true
VOICE_INCLUDE_LATENCY_META=true

# Google AI Studio Gemini Native Audio Dialog
GOOGLE_API_KEY=
# Optional alias if you prefer this name
GEMINI_API_KEY=
# Use Gemini Live API (bidiGenerateContent) as primary runtime
GEMINI_USE_LIVE_API=true
# Native Audio Dialog / Live model (must support bidiGenerateContent)
GEMINI_LIVE_MODEL=models/gemini-2.5-flash-native-audio-latest
# Dialog model for understanding and reasoning (STT+LLM style turn)
GEMINI_DIALOG_MODEL=gemini-2.5-flash
# Backward-compatible alias (used only when GEMINI_DIALOG_MODEL is empty)
GEMINI_MODEL=
# TTS model for natural speech synthesis
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_VOICE_NAME=Aoede
GEMINI_LANGUAGE=es-ES
GEMINI_TIMEOUT_MS=12000
GEMINI_MAX_OUTPUT_TOKENS=512
GEMINI_TEMPERATURE=0.35
GEMINI_RESPONSE_MODALITIES=TEXT

# Optional business context from TankGo gateway
VOICE_ENABLE_GAS_CONTEXT=false
GATEWAY_BASE_URL=http://gateway:8080
VOICE_GATEWAY_TIMEOUT_MS=5000
VOICE_MAX_KM=25
INTERNAL_API_SECRET=

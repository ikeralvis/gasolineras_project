# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=8080

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/usuarios?sslmode=disable

# Auth
JWT_SECRET=replace-with-a-strong-32+char-secret
JWT_EXPIRES_IN=7d
COOKIE_SECRET=

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Internal S2S auth (optional when using IAM-only)
USE_INTERNAL_API_SECRET=false
INTERNAL_API_SECRET=

# Optional resilience integration with gasolineras-service
GASOLINERAS_SERVICE_URL=http://localhost:8000
FAVORITES_VALIDATE_ON_WRITE=false

# Optional for Swagger server URL
USUARIOS_URL=http://localhost:8080

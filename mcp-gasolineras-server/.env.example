# Endpoint del gateway (recomendado para no depender de accesos directos a cada microservicio)
GATEWAY_BASE_URL=http://gateway:8080

# Seguridad interna para endpoints protegidos
INTERNAL_API_SECRET=replace-me

# Token JWT opcional para tools de usuario (/api/usuarios/me, /api/usuarios/favoritos)
# Si no se define, cada tool debe recibir authToken por input.
DEFAULT_USER_BEARER_TOKEN=

# Timeout de llamadas a servicios
HTTP_TIMEOUT_MS=10000

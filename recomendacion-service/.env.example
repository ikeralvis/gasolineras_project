# ============================================================================
# RECOMENDACION-SERVICE: ENV PARA GOOGLE CLOUD RUN
# ============================================================================

# =====================
# 1) MINIMO OBLIGATORIO
# =====================

# Cloud Run inyecta PORT automaticamente. Se deja por compatibilidad local.
PORT=8080
LOG_LEVEL=info

# Motor de routing principal
# ors | osrm
ROUTING_BACKEND=ors

# Solo obligatorio cuando ROUTING_BACKEND=ors (guardar en Secret Manager)
ORS_API_KEY=

# Origen de datos de gasolineras (elige UNA opcion):
# - Modular (menos dependencia): https://gasolineras-service-<hash>-<region>.run.app/gasolineras/?limit=20000
# - Centralizada via gateway:    https://gateway-hono-<hash>-<region>.run.app/api/gasolineras/?limit=20000
GASOLINERAS_API_URL=https://gasolineras-service-REEMPLAZAR.run.app/gasolineras/?limit=20000

# Como buscar candidatas en ruta: api | postgis | auto
# En Cloud Run sin DB directa: usar api
ROUTE_CANDIDATES_SOURCE=api

# Politica para evitar recomendar estaciones "de pueblo" cuando sea posible
# off | prefer | strict
ACCESS_FILTER_MODE=strict

# Proveedor para clasificacion de acceso vial
# osm | mapbox | google | auto
POI_ACCESS_PROVIDER=osm


# =============================
# 2) RECOMENDADO (NO OBLIGATORIO)
# =============================

ROUTING_FAILOVER_TO_OSRM=true
ALLOW_STRAIGHT_LINE_FALLBACK=false
ROUTING_HTTP_RETRIES=2
ROUTING_RETRY_BACKOFF_S=0.5
ROUTING_TIMEOUT_S=10
GASOLINERAS_TIMEOUT_S=15

DEFAULT_WEIGHT_PRICE=0.6
DEFAULT_WEIGHT_DETOUR=0.4
DEFAULT_MAX_DESVIO_KM=5.0
DEFAULT_MAX_DESVIO_MIN=5.0
PRE_FILTER_RADIUS_KM=20.0

MAX_REAL_DETOUR_CHECKS=30
MATRIX_MAX_CANDIDATES=60
POSTGIS_ROUTE_MAX_CANDIDATES=1500


# =========================================
# 3) OPCIONAL AVANZADO (SOLO SI LO NECESITAS)
# =========================================

# ORS endpoint
ORS_BASE_URL=https://api.openrouteservice.org

# OSRM endpoint (si usas ROUTING_BACKEND=osrm)
OSRM_BASE_URL=http://router.project-osrm.org

# Fallback de fuente publica de gasolineras si falla GASOLINERAS_API_URL
GOBIERNO_API_URL=https://sedeaplicaciones.minetur.gob.es/ServiciosRESTCarburantes/PreciosCarburantes/EstacionesTerrestres/

# Solo si usas candidatos por PostGIS
DATABASE_URL=

# Enriquecimiento de POI (NO obligatorio)
ACCESS_ENRICHMENT_TOP_N=10
ACCESS_ENRICHMENT_TIMEOUT_S=6

# Solo si POI_ACCESS_PROVIDER=mapbox
MAPBOX_SEARCH_BASE_URL=https://api.mapbox.com/geocoding/v5/mapbox.places
MAPBOX_ACCESS_TOKEN=

# Solo si POI_ACCESS_PROVIDER=google
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com/v1/places:searchNearby
GOOGLE_PLACES_API_KEY=

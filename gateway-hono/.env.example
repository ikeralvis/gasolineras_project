# Puerto del Gateway
PORT=8080

# URL publica del gateway (opcional, recomendado en cloud)
# GATEWAY_PUBLIC_URL=https://tu-gateway.onrender.com

# URLs de los microservicios (Docker / red interna)
USUARIOS_SERVICE_URL=http://usuarios:3001
GASOLINERAS_SERVICE_URL=http://gasolineras:8000
RECOMENDACION_SERVICE_URL=http://recomendacion:8001
EV_CHARGING_SERVICE_URL=http://ev-charging:8000

# Opcional: servicio de prediccion (si se expone via HTTP)
# PREDICTION_SERVICE_URL=http://prediction:8004

# URLs de los microservicios (Desarrollo local)
# USUARIOS_SERVICE_URL=http://localhost:3001
# GASOLINERAS_SERVICE_URL=http://localhost:8000
# RECOMENDACION_SERVICE_URL=http://localhost:8001
# EV_CHARGING_SERVICE_URL=http://localhost:8003
# PREDICTION_SERVICE_URL=http://localhost:8004

# Frontend URL para CORS
FRONTEND_URL=http://localhost:5173
# Lista adicional de orígenes permitidos en CORS (separados por coma)
# FRONTEND_URLS=https://app.tu-dominio.com,https://admin.tu-dominio.com

# Google OAuth
GOOGLE_CLIENT_ID=tu-google-client-id

# 🔐 Secret compartido para comunicación interna entre servicios
# IMPORTANTE: Cambiar en producción a un valor aleatorio de al menos 32 caracteres
INTERNAL_API_SECRET=cambiar-este-secret-en-produccion-minimo-32-chars

# Modo de ejecución
NODE_ENV=development

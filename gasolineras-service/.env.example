# -----------------------------
# Runtime
# -----------------------------
APP_ENV=development
PORT=8080

# -----------------------------
# Database
# -----------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gasolineras?sslmode=disable

# -----------------------------
# API / CORS
# -----------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# -----------------------------
# External clients
# -----------------------------
GOBIERNO_API_URL=https://sedeaplicaciones.minetur.gob.es/ServiciosRESTCarburantes/PreciosCarburantes/EstacionesTerrestres/
API_TIMEOUT=30
USUARIOS_SERVICE_URL=http://usuarios:3001
EV_EXTERNAL_API_BASE=https://www.mapareve.es/api/public/v1

# -----------------------------
# Sync behavior
# -----------------------------
AUTO_ENSURE_FRESH_ON_STARTUP=true
AUTO_SYNC_ON_READ=false
AUTO_SYNC_COOLDOWN_MINUTES=30
HISTORICAL_SCOPE=all
HISTORY_RETENTION_DAYS=30
FORCE_MEMORY_MODE=false

# -----------------------------
# Internal auth (optional)
# Keep disabled when using IAM-only between services.
# -----------------------------
USE_INTERNAL_API_SECRET=false
INTERNAL_API_SECRET=

# -----------------------------
# Raw export to GCS (optional)
# -----------------------------
RAW_EXPORT_ENABLED=false
RAW_EXPORT_GCS_BUCKET=
RAW_EXPORT_GCS_PREFIX=raw/
RAW_EXPORT_PARQUET_COMPRESSION=snappy

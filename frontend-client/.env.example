# ==============================
# Frontend base config
# ==============================
# API Gateway base URL (recommended single entrypoint)
VITE_API_BASE_URL=http://localhost:8080

# ==============================
# Optional direct microservice URLs
# (useful for local debugging, gateway fallbacks, or diagnostics)
# ==============================
VITE_GASOLINERAS_API_URL=http://localhost:8000
VITE_RECOMENDACION_API_URL=http://localhost:8086
VITE_USUARIOS_API_URL=http://localhost:3001
VITE_CHARGING_API_URL=http://localhost:8091
VITE_VOICE_SERVICE_URL=http://localhost:8090

# Voice assistant websocket (direct; gateway can proxy this too)
VITE_VOICE_WS_URL=ws://localhost:8090/ws/voice

# ==============================
# Google OAuth
# ==============================
# Obtain from Google Cloud Console > APIs & Services > Credentials
VITE_GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com

# ==============================
# Maps and tiles
# ==============================
# Default app tiles if unset: CARTO light_all
VITE_MAP_TILE_URL=https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png
VITE_MAP_TILE_ATTRIBUTION=&copy; <a href='https://carto.com/attributions'>CARTO</a>

# Optional map provider token(s)
VITE_MAPBOX_TOKEN=

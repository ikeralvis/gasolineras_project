# ===================================
# CONFIGURACIÓN GLOBAL DEL PROYECTO
# Sistema de Gasolineras - Microservicios
# ===================================

# ===================================
# PUERTOS DE SERVICIOS
# ===================================
POSTGRES_PORT=5432
MONGO_PORT=27017
FRONTEND_PORT=80
GATEWAY_PORT=8080
USUARIOS_PORT=3001
GASOLINERAS_PORT=8000

# ===================================
# POSTGRESQL (usuarios-service)
# ===================================
DB_USER=postgres
DB_PASSWORD=admin
DB_NAME=usuarios_db
DB_HOST=postgres
DB_PORT=5432

# ===================================
# CONFIGURACIÓN DEL SERVIDOR (usuarios-service)
# ===================================
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ===================================
# JWT (usuarios-service)
# ===================================
# 🔐 IMPORTANTE: Genera un secreto seguro con: node generate-jwt-secret.ps1
JWT_SECRET=tu-secreto-jwt-aqui-generalo-con-el-script
JWT_EXPIRES_IN=7d

# ===================================
# CORS - GLOBAL PARA TODOS LOS SERVICIOS
# ===================================
# 🔴 CRÍTICO: Lista de orígenes permitidos separados por coma
# Añade los dominios de producción cuando despliegues
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80

# ===================================
# MONGODB (gasolineras-service)
# ===================================
# Credenciales de MongoDB para Docker Compose
MONGO_INITDB_ROOT_USERNAME=user_gasolineras
MONGO_INITDB_ROOT_PASSWORD=secret_mongo_pwd
MONGO_DB_NAME=db_gasolineras
MONGO_HOST=mongo

# Variables para el microservicio de gasolineras
MONGO_USER=
MONGO_PASS=
MONGO_DB=gasolineras_db

# ===================================
# API DEL GOBIERNO DE ESPAÑA (gasolineras-service)
# ===================================
GOBIERNO_API_URL=https://sedeaplicaciones.minetur.gob.es/ServiciosRESTCarburantes/PreciosCarburantes/EstacionesTerrestres/
API_TIMEOUT=30

# CORS para gasolineras-service (usa la misma lista que usuarios)
# CORS_ORIGINS ya está definido globalmente con ALLOWED_ORIGINS

# ===================================
# LOGGING - GLOBAL
# ===================================
# Niveles: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===================================
# URLs DE SERVICIOS
# ===================================
USUARIOS_SERVICE_URL=http://usuarios:3001
GASOLINERAS_SERVICE_URL=http://gasolineras:8000
RECOMENDACION_SERVICE_URL=http://recomendacion:8001
GATEWAY_URL=http://localhost:8080

# ===================================
# RECOMENDACIÓN SERVICE
# ===================================
RECOMENDACION_PORT=8002

# Motor de routing: "ors" (recomendado) o "osrm" (self-hosted)
ROUTING_BACKEND=ors

# OpenRouteService – registro gratuito en https://openrouteservice.org/
# Plan free: 2 000 req/día (suficiente para desarrollo y PFG)
ORS_API_KEY=tu-ors-api-key-aqui

# URL pública del gateway cuando esté desplegado en producción (Google Cloud):
# GASOLINERAS_API_URL=https://gateway-XXXX-ew.a.run.app/api/gasolineras/?limit=2000

# ===================================
# VARIABLES PARA LOCAL
# ===================================
ENVIRONMENT=local
USE_TLS=false
TLS_ALLOW_INVALID_CERTS=true

# ===================================
# CONFIGURACIÓN DE GOOGLE OAUTH2 (usuarios-service)
# ===================================
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/usuarios/google/callback
FRONTEND_URL=http://localhost:80

# ===================================
# NOTAS IMPORTANTES
# ===================================
# 1. NO SUBIR ESTE ARCHIVO .env A GIT (ya está en .gitignore)
# 2. Copiar .env.example a .env y configurar valores reales
# 3. En producción, usar variables de entorno del sistema o secrets manager
# 4. Generar JWT_SECRET con: node generate-jwt-secret.ps1


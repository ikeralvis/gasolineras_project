# ===================================
# CONFIGURACION GLOBAL DEL PROYECTO
# Gasolineras Project (cloud native)
# ===================================

# ===================================
# DATABASE CLOUD (Neon / Supabase PostgreSQL)
# ===================================
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ===================================
# PUERTOS DE SERVICIOS
# ===================================
FRONTEND_PORT=80
GATEWAY_PORT=8080
USUARIOS_PORT=3001
GASOLINERAS_PORT=8000
RECOMENDACION_PORT=8002
VOICE_ASSISTANT_PORT=8090

# ===================================
# CONFIGURACION BASE
# ===================================
HOST=0.0.0.0
NODE_ENV=development
ENVIRONMENT=local
USE_TLS=false
TLS_ALLOW_INVALID_CERTS=true

# ===================================
# JWT (usuarios-service)
# ===================================
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
COOKIE_SECRET=replace-or-leave-empty

# ===================================
# CORS / URLS
# ===================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80
FRONTEND_URL=http://localhost:80
FRONTEND_URLS=
GATEWAY_URL=http://localhost:8080
GATEWAY_PUBLIC_URL=

# ===================================
# SERVICIOS INTERNOS
# ===================================
USUARIOS_SERVICE_URL=http://usuarios:3001
GASOLINERAS_SERVICE_URL=http://gasolineras:8000
RECOMENDACION_SERVICE_URL=http://recomendacion:8001
VOICE_ASSISTANT_SERVICE_URL=http://voice-assistant:8090
PREDICTION_SERVICE_URL=

# ===================================
# SEGURIDAD INTERNA
# ===================================
INTERNAL_API_SECRET=replace-with-long-random-secret

# ===================================
# GASOLINERAS DATA FRESHNESS
# ===================================
GOBIERNO_API_URL=https://sedeaplicaciones.minetur.gob.es/ServiciosRESTCarburantes/PreciosCarburantes/EstacionesTerrestres/
API_TIMEOUT=30
AUTO_ENSURE_FRESH_ON_STARTUP=true
AUTO_SYNC_ON_READ=false
AUTO_SYNC_COOLDOWN_MINUTES=30
HISTORICAL_SCOPE=all
GASOLINERAS_AUTO_ENSURE_FRESH_ENABLED=true
GASOLINERAS_STARTUP_ENSURE_FRESH=true
GASOLINERAS_AUTO_ENSURE_INTERVAL_MINUTES=60
RAW_EXPORT_ENABLED=false
RAW_EXPORT_GCS_BUCKET=
RAW_EXPORT_GCS_PREFIX=raw/
RAW_EXPORT_PARQUET_COMPRESSION=snappy

# Prediction station selection (si habilitas prediction-service profile ml)
PREDICTION_SOURCE_MODE=favorites
PREDICTION_FAVORITES_SOURCE=usuarios-service
PREDICTION_TOP_N_STATIONS=500
PREDICTION_MIN_FAVORITES_COUNT=1

# ===================================
# GATEWAY TUNING
# ===================================
OPENAPI_TIMEOUT_MS=12000
HEALTH_TIMEOUT_MS=12000
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_USER_AGENT=TankGo/1.0 (geocoding proxy)

# ===================================
# RECOMENDACION SERVICE
# ===================================
ROUTING_BACKEND=ors
ROUTING_FAILOVER_TO_OSRM=false
ALLOW_STRAIGHT_LINE_FALLBACK=false
OSRM_BASE_URL=http://router.project-osrm.org
ORS_API_KEY=replace-with-ors-key
LOG_LEVEL=INFO

# ===================================
# GOOGLE OAUTH (usuarios-service)
# ===================================
GOOGLE_CLIENT_ID=replace-google-client-id
GOOGLE_CLIENT_SECRET=replace-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/usuarios/google/callback

# ===================================
# AI - GEMINI (voice assistant)
# ===================================
GOOGLE_API_KEY=
# Alias opcional, puedes usar solo una de las dos
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-preview-native-audio-dialog
GEMINI_VOICE_NAME=Aoede
GEMINI_LANGUAGE=es-ES
GEMINI_TIMEOUT_MS=12000
GEMINI_MAX_OUTPUT_TOKENS=512
GEMINI_TEMPERATURE=0.35
GEMINI_RESPONSE_MODALITIES=TEXT,AUDIO

# ===================================
# AI - VOICE GUARDRAILS
# ===================================
VOICE_RATE_LIMIT_WINDOW_MS=60000
VOICE_RATE_LIMIT_MAX_REQUESTS=40
VOICE_MAX_TEXT_CHARS=450
VOICE_MAX_AUDIO_BASE64_CHARS=5500000
VOICE_MAX_STREAM_CHUNKS=32
VOICE_MAX_KM=25
VOICE_ALLOWED_ORIGINS=*
VOICE_INCLUDE_AUDIO_BY_DEFAULT=true
VOICE_ENABLE_GAS_CONTEXT=false
VOICE_GATEWAY_TIMEOUT_MS=5000
VOICE_WS_HEARTBEAT_INTERVAL_MS=25000
VOICE_WS_IDLE_TIMEOUT_MS=240000

# ===================================
# MCP SERVER
# ===================================
MCP_GATEWAY_MODE=rest
MCP_HTTP_TIMEOUT_MS=10000

# ===================================
# NOTAS
# ===================================
# 1. Copia este archivo a .env y rellena valores reales
# 2. No subas .env a git
# 3. Para voz con AI Studio, configura GOOGLE_API_KEY y cuotas de Gemini API
